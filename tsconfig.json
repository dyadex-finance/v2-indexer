{
  "compilerOptions": {
    "target": "es2022",
    "lib": [
      "es2022"
    ],
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src",
    "envio-env.d.ts"
  ]
}